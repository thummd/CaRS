# HTCondor submission file for DS3M extended seed sweep
# Usage: condor_submit_bid 100 ds3m_seed_sweep_extended.sub
#
# Goal: Find more seeds with optimal regime splits for ensemble

Universe = vanilla
Executable = /lustre/home/dthumm/CASTOR/electricity/htcondor/run_ds3m_multivariate_job.sh

# Arguments: COUNTRY MODE D_DIM SEED
Arguments = $(country) $(mode) $(d_dim) $(seed)

# Logs
Log = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/seed_ext_$(country)_$(mode)_d$(d_dim)_seed$(seed).log
Output = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/seed_ext_$(country)_$(mode)_d$(d_dim)_seed$(seed).out
Error = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/seed_ext_$(country)_$(mode)_d$(d_dim)_seed$(seed).err

# Resource requirements
Request_CPUs = 2
Request_Memory = 8GB

# GPU for faster training
Request_GPUs = 1
Requirements = (CUDAGlobalMemoryMb >= 4000) && (TARGET.CUDACapability >= 6.0)

# Don't restart on preemption
OnExitRemove = true

# Queue jobs from params file
Queue country, mode, d_dim, seed from /lustre/home/dthumm/CASTOR/electricity/htcondor/job_params_seed_sweep_extended.txt
