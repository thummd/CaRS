Universe = vanilla
Executable = /lustre/home/dthumm/CASTOR/electricity/htcondor/run_ds3m_spread_regimes.sh

# Arguments: D_DIM SEED
Arguments = $(d_dim) $(seed)

# Logs
Log = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/ds3m_spread_regime_d$(d_dim)_s$(seed).log
Output = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/ds3m_spread_regime_d$(d_dim)_s$(seed).out
