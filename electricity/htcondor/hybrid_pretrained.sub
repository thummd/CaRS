# HTCondor submission for Option B: Pre-trained DS3M Regimes
universe = vanilla
executable = /lustre/home/dthumm/CASTOR/electricity/htcondor/run_hybrid_pretrained.sh

# Arguments: country, d_dim, seed
arguments = $(country) $(d_dim) $(seed)

# Resource requirements
request_cpus = 4
request_memory = 32G
request_gpus = 1
Requirements = (CUDAGlobalMemoryMb >= 40000) && (TARGET.CUDACapability >= 6.0)

# Environment
getenv = True

# Output files
output = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/hybrid_pretrained_$(country)_d$(d_dim)_s$(seed).out
error = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/hybrid_pretrained_$(country)_d$(d_dim)_s$(seed).err
log = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/hybrid_pretrained_$(country)_d$(d_dim)_s$(seed).log

# Job parameters from file
queue country, d_dim, seed from /lustre/home/dthumm/CASTOR/electricity/htcondor/job_params_hybrid_fixes.txt
