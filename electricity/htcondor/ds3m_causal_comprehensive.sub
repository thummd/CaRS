# Comprehensive DS3MCausal experiments - all targets, regimes, and tasks
# Tests the edge learning fix with init_logits [1.0, 1.0] and min_edge_penalty = 1.0

Universe = vanilla
Executable = /lustre/home/dthumm/CASTOR/electricity/htcondor/run_multiseed_job.sh

# Resource requirements
RequestCpus = 2
RequestMemory = 16384
RequestGPUs = 1
Requirements = (CUDAGlobalMemoryMb >= 12000) && (TARGET.CUDACapability >= 6.0)

# Environment
GetEnv = True

# Job configuration
+MaxRuntime = 14400
+JobBatchName = "ds3m_causal_comprehensive"

