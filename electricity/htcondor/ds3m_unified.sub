# HTCondor submission file for DS3M on unified electricity data
# Usage: condor_submit_bid 100 ds3m_unified.sub

Universe = vanilla
Executable = /lustre/home/dthumm/CASTOR/electricity/htcondor/run_ds3m_unified.sh

# Arguments: COUNTRY FEATURE_GROUPS SEED
Arguments = $(country) $(feature_groups) $(seed)

# Logs
Log = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/ds3m_$(country)_$(seed).log
Output = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/ds3m_$(country)_$(seed).out
Error = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/ds3m_$(country)_$(seed).err

# Resource requirements
Request_CPUs = 4
Request_Memory = 16GB
Request_GPUs = 1

# GPU requirements
Requirements = (CUDAGlobalMemoryMb >= 8000) && (TARGET.CUDACapability >= 6.0)

# Time limit: 2 hours per job
MaxTime = 7200

# Don't restart on preemption
OnExitRemove = true

# Queue jobs from params file
Queue country, feature_groups, seed from /lustre/home/dthumm/CASTOR/electricity/htcondor/job_params_ds3m_unified.txt
