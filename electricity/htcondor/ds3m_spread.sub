# HTCondor submission file for DS3M spread prediction
# Usage: condor_submit_bid 100 ds3m_spread.sub

Universe = vanilla
Executable = /lustre/home/dthumm/CASTOR/electricity/htcondor/run_ds3m_spread.sh

# Arguments: SEED D_DIM
Arguments = $(seed) $(d_dim)

# Logs
Log = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/ds3m_spread_d$(d_dim)_seed$(seed).log
Output = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/ds3m_spread_d$(d_dim)_seed$(seed).out
Error = /lustre/home/dthumm/CASTOR/electricity/htcondor/logs/ds3m_spread_d$(d_dim)_seed$(seed).err

# Resource requirements
Request_CPUs = 4
Request_Memory = 16GB
Request_GPUs = 1

# GPU requirements
Requirements = (CUDAGlobalMemoryMb >= 8000) && (TARGET.CUDACapability >= 6.0)

# Time limit: 2 hours per job
MaxTime = 7200

# Don't restart on preemption
OnExitRemove = true

# Queue jobs from params file
Queue seed, d_dim from /lustre/home/dthumm/CASTOR/electricity/htcondor/job_params_ds3m_spread.txt
